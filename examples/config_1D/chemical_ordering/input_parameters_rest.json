{
  "schema_version": 2,
  "paths": {
    "config_root": ".",
    "structure_file": "slice_chemical_ordering_1d.f1d",
    "output_directory": "./output_chem_rest"
  },
  "structure": {
    "dimension": 1,
    "coefficients": {
      "source": "config"
    }
  },
  "reciprocal_space": {
    "intervals": [
      {
        "limit": [1.0],
        "subvolume_step": [1.0]
      }
    ],
    "mask": {
      "equation": "((Mod(h,1.0) - 0.5)**2 > (0.198**2))"
    }
  },
  "processing": {
    "mode": "chemical",
    "method": "from_average",
    "num_chunks": 1,
    "fresh_start": true,
    "run_postprocessing": true,
    "points": [
      {
        "selector": {
          "element": "El1",
          "reference_number": 1
        },
        "window": {
          "dist_from_atom_center": [0.01],
          "step_in_angstrom": [0.05]
        }
      }
    ],
    "chemical_filtered_ordering": true,
    "coefficients": {
      "center_by": "global",
      "use": true
    }
  },
  "runtime": {
    "dask": {
      "backend": "synchronous",
      "max_workers": 1,
      "threads_per_worker": 1,
      "processes": false,
      "worker_wait_timeout": "30s"
    }
  }
}
