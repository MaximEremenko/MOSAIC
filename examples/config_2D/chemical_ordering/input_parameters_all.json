{
  "schema_version": 2,
  "paths": {
    "config_root": ".",
    "structure_file": "sample_2d_chem_PMN_2Dcol10.f2d",
    "output_directory": "./output_chem_all"
  },
  "structure": {
    "dimension": 2,
    "coefficients": {
      "source": "config"
    }
  },
  "reciprocal_space": {
    "intervals": [
      {
        "limit": [40.0, 40.0],
        "subvolume_step": [5.0, 5.0]
      }
    ],
    "mask": {
      "equation": "((Mod(h,1.0) - 0.5)**2 + (Mod(k,1.0) - 0.5)**2 >= 0)"
    }
  },
  "processing": {
    "mode": "chemical",
    "method": "from_average",
    "num_chunks": 1,
    "fresh_start": true,
    "run_postprocessing": true,
    "points": [
      {
        "selector": {
          "element": "El1",
          "reference_number": 1
        },
        "window": {
          "dist_from_atom_center": [0.8, 0.8],
          "step_in_angstrom": [0.8125, 0.8125]
        }
      }
    ],
    "chemical_filtered_ordering": true,
    "coefficients": {
      "center_by": "global",
      "use": true
    }
  },
  "runtime": {
    "dask": {
      "backend": "cuda-local",
      "max_workers": 1,
      "threads_per_worker": 1,
      "processes": false,
      "worker_wait_timeout": "30s"
    }
  }
}
