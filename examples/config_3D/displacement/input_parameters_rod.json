{
  "schema_version": 2,
  "paths": {
    "config_root": ".",
    "structure_file": "Catio3.rmc6f",
    "output_directory": "./output_disp_rod",
    "average_structure_file": "Catio3_average.rmc6f"
  },
  "structure": {
    "dimension": 3,
    "cell_limits": {
      "min": [0, 0, 0],
      "max": [15, 15, 15]
    }
  },
  "reciprocal_space": {
    "intervals": [
      {
        "limit": [20.0, 20.0, 20.0],
        "subvolume_step": [5.0, 5.0, 5.0]
      }
    ],
    "mask": {
      "equation": "(((Mod(h,1.0) - 0.5)**2 + (Mod(k,1.0) - 0.5)**2) <= (0.1876)**2) & (((Mod(h,1.0) - 0.5)**2 + (Mod(k,1.0) - 0.5)**2 + (Mod(l,1.0) - 0.5)**2) >= (0.2501)**2)"
    }
  },
  "processing": {
    "mode": "displacement",
    "method": "from_average",
    "num_chunks": 4,
    "fresh_start": true,
    "run_postprocessing": true,
    "points": [
      {
        "selector": {
          "element": "O",
          "reference_number": 2
        },
        "window": {
          "dist_from_atom_center": [0.5, 0.5, 0.5],
          "step_in_angstrom": [0.05, 0.05, 0.05]
        }
      },
      {
        "selector": {
          "element": "O",
          "reference_number": 3
        },
        "window": {
          "dist_from_atom_center": [0.5, 0.5, 0.5],
          "step_in_angstrom": [0.05, 0.05, 0.05]
        }
      },
      {
        "selector": {
          "element": "O",
          "reference_number": 4
        },
        "window": {
          "dist_from_atom_center": [0.5, 0.5, 0.5],
          "step_in_angstrom": [0.05, 0.05, 0.05]
        }
      }
    ]
  },
  "runtime": {
    "dask": {
      "backend": "local",
      "max_workers": 2,
      "threads_per_worker": 16,
      "processes": false,
      "worker_wait_timeout": "120s"
    },
    "scattering_weights": {
      "kind": "ones",
      "calculator": "default"
    }
  }
}
