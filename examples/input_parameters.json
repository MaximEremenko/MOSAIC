{
  "schema_version": 2,
  "paths": {
    "config_root": ".",
    "structure_file": "sample_1d.f1d",
    "output_directory": "./sample_1d_release"
  },
  "structure": {
    "dimension": 1
  },
  "reciprocal_space": {
    "intervals": [
      {
        "limit": [1.0],
        "subvolume_step": [1.0]
      }
    ],
    "mask": {
      "equation": "h**2>=-1"
    }
  },
  "processing": {
    "mode": "displacement",
    "method": "central",
    "num_chunks": 1,
    "fresh_start": true,
    "run_postprocessing": false,
    "points": [
      {
        "selector": {
          "file": "central_points.txt"
        },
        "window": {
          "dist_from_atom_center": [0.1],
          "step_in_angstrom": [0.05]
        }
      }
    ]
  },
  "runtime": {
    "dask": {
      "backend": "local",
      "max_workers": 1,
      "threads_per_worker": 1,
      "processes": false,
      "worker_wait_timeout": "30s"
    },
    "form_factor": {
      "family": "neutron",
      "calculator": "default"
    }
  }
}
